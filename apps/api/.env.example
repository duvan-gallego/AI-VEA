APP_NAME=AI VEA API
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
VIDEO_UPLOAD_DIR=storage/uploads
VIDEO_MAX_UPLOAD_BYTES=524288000
VIDEO_ALLOWED_CONTENT_TYPES=["video/mp4","video/mpeg","video/quicktime","video/webm","video/x-matroska"]
VIDEO_ALLOWED_EXTENSIONS=[".mp4",".mpeg",".mov",".webm",".mkv"]
WHISPER_MODEL_SIZE=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_LOCAL_FILES_ONLY=true
FFMPEG_PATH=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.1
LLM_RESPONSE_FORMAT=json_schema
